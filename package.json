{
  "name": "screenshot-translator",
  "version": "0.1.0",
  "description": "A lightweight Windows screenshot OCR and translation tool.",
  "main": "dist/main/main.js",
  "private": true,
  "scripts": {
    "build": "tsc -p tsconfig.json && node scripts/copy-static.mjs",
    "start": "npm run build && electron .",
    "dev": "npm run build && electron .",
    "pack:win": "npm run build && electron-builder --win portable"
  },
  "dependencies": {
    "tesseract.js": "^6.0.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "electron": "^33.3.0",
    "electron-builder": "^25.1.8",
    "typescript": "^5.7.3"
  },
  "build": {
    "appId": "com.codex.screenshottranslator",
    "productName": "截图翻译工具",
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": [
        "portable"
      ]
    }
  }
}
